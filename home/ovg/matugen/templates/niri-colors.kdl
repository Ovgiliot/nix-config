// Generated by matugen — included at top level of config.kdl so niri's
// top-level-only include restriction is respected. Overrides the
// focus-ring and shadow color defined in layout.kdl.
layout {
    focus-ring {
        width 1
        active-color "{{colors.primary.default.hex}}"
        inactive-color "{{colors.outline.default.hex}}"
    }
    shadow {
        color "#{{colors.shadow.default.hex_stripped}}07"
    }
}
